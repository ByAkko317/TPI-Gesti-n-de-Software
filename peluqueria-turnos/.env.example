# --- Base de datos ---
# En Docker Compose se sobrescribe apuntando al servicio 'db'.
DATABASE_URL=postgresql+psycopg://peluqueria:peluqueria@db:5432/peluqueria

# --- JWT (se usa a fondo en la Etapa 2) ---
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Admin sembrado por seed.py ---
ADMIN_EMAIL=admin@peluqueria.com
ADMIN_PASSWORD=admin1234
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=Peluqueria

# --- n8n (se usa en la etapa de automatización) ---
# En Docker Compose, n8n resuelve por el nombre del servicio.
N8N_WEBHOOK_URL=http://n8n:5678/webhook/peluqueria-notificaciones
# Token que n8n usa para llamar al endpoint interno de recordatorios.
INTERNAL_API_TOKEN=change-me-internal-token

# --- Frontend (CORS) ---
FRONTEND_ORIGIN=http://localhost:5173

# --- Reglas de negocio de turnos ---
OPENING_HOUR=9
CLOSING_HOUR=18
# Días abiertos: 0=lunes ... 6=domingo. Por defecto L-S.
OPEN_WEEKDAYS=0,1,2,3,4,5
MIN_ADVANCE_MINUTES=60
